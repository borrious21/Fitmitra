-- Migration: add blood pressure and heart rate to progress_logs
-- Run this once against your database

ALTER TABLE progress_logs
  ADD COLUMN IF NOT EXISTS blood_pressure_systolic  INTEGER,
  ADD COLUMN IF NOT EXISTS blood_pressure_diastolic INTEGER,
  ADD COLUMN IF NOT EXISTS blood_pressure            VARCHAR(20),
  ADD COLUMN IF NOT EXISTS heart_rate               INTEGER;

-- Optional: add a check constraint for sane BP ranges
ALTER TABLE progress_logs
  ADD CONSTRAINT IF NOT EXISTS chk_bp_systolic
    CHECK (blood_pressure_systolic  IS NULL OR (blood_pressure_systolic  BETWEEN 60  AND 250)),
  ADD CONSTRAINT IF NOT EXISTS chk_bp_diastolic
    CHECK (blood_pressure_diastolic IS NULL OR (blood_pressure_diastolic BETWEEN 40  AND 150)),
  ADD CONSTRAINT IF NOT EXISTS chk_heart_rate
    CHECK (heart_rate               IS NULL OR (heart_rate               BETWEEN 30  AND 250));